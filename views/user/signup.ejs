<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
    <meta name="author" content="Khang">
    <meta name="keywords" content="mira, bot">
    <title>Sign up | Mira</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css" />
    <link rel="stylesheet" href="/r/c/user.signup.css">
    <script src="/r/j/user.signup.js"></script>
</head>

<body>
    <main>
        <div class="main-text">
            <div class="text">Sign up</div>
            <form>
                <div class="field">
                    <input type="text" name="email" id="email" required>
                    <span id="icon_1" class="fas fa-user"></span>
                    <label>Email</label>
                </div>
                <div class="field">
                    <input type="password" name="password" id="password" required>
                    <span id="icon_1" class="fas fa-lock"></span>
                    <span class="fas fa-eye" id="togglePassword" style="cursor: pointer;"></span>
                    <label>Password</label>
                </div>
                <div class="field">
                    <input type="text" name="verifyCode" id="verifyCode" maxlength="6" inputmode="numeric" required>
                    <span id="icon_1" class="fas fa-lock"></span>
                    <button class="sendCode" id="sendCode" style="cursor: pointer;">Send</button>
                    <label>Verification code</label>
                </div>
                <div class="accept">
                    <label for="accept">
                        <input type="checkbox" id="accept" required>
                        <p>I Agree To <a href="/terms-conditions">The Terms And Conditions</a></p>
                    </label>
                </div>
                <button class="sendClient" type="submit">Sign up</button>
            </form>
            <div class="signup-link">
                <p>Already have an account? <a href="/user/signin">Sign in here</a></p>
            </div>
        </div>
        <div class="main-image">
            <img src="/r/a/user.signin.png" alt="">
        </div>
    </main>
</body>

</html>